# Copy this file to deploy/systemd/thesis.env on the deployment machine.
# Values below are safe defaults; adjust as needed.

PROJECT_ROOT=/home/pi/projects/CpE-Practice-and-Design
PYTHON_BIN=/home/pi/projects/CpE-Practice-and-Design/.venv/bin/python3

SENSOR_EVENT_URL=http://127.0.0.1:5000/api/sensors/event
SENSOR_API_KEY=
REACT_DASHBOARD_ENABLED=1

MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=thesis_ingest
MQTT_BROKER_PASSWORD=change_me
MQTT_TOPIC_ROOT=thesis/v1
MQTT_INGEST_CLIENT_ID=thesis-mqtt-ingest
MQTT_INGEST_QOS=1
MQTT_INGEST_RETRY_SECONDS=5
MQTT_INGEST_STATUS_INTERVAL=20

VISION_EVENT_SINK=mqtt
